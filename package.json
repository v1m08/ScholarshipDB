{
  "name": "open-scholar-index",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "index": "node scripts/build-index.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/prod-check.mjs && node scripts/build-index.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "pretest": "node scripts/build-index.mjs",
    "test": "node --test tests/*.test.mjs",
    "db:publish": "node scripts/publish-supabase.mjs",
    "db:scholarship": "node scripts/scholarship-db.mjs",
    "db:prune-duplicates": "node scripts/prune-supabase-duplicates.mjs",
    "phase-a:bigfuture": "node --max-old-space-size=4096 scripts/knowledge/phase-a-bigfuture.mjs",
    "prod:check": "node scripts/prod-check.mjs --strict"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
