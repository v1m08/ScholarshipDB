{
  "name": "open-scholar-index",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "index": "node scripts/build-index.mjs",
    "dev": "node scripts/build-index.mjs && next dev",
    "prebuild": "node scripts/prod-check.mjs && node scripts/build-index.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "pretest": "node scripts/build-index.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:enrichment": "python scripts/enrichment/test_enrich_v4.py",
    "data:enrich": "python scripts/enrichment/enrich_v4.py run --limit 100 --workers 1 --crawl-workers 1 --model-batch-size 5 --batch-source-chars 800 --model-timeout 240 --max-output-tokens 12288 --delay 3 --retries 2 --retry-delay 15 --upgrade-prefill --retry-failed --no-batch-fallback --record-only && node scripts/build-index.mjs",
    "data:status": "python scripts/enrichment/enrich_v4.py status --limit 0 --summary-only",
    "data:audit": "python scripts/enrichment/enrich_v4.py audit --limit 100 --summary-only",
    "db:publish": "node scripts/publish-supabase.mjs",
    "prod:check": "node scripts/prod-check.mjs --strict"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
